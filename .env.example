# ── LLM backend ──────────────────────────────────────────────────────────────
# Options: anthropic | lm_studio
LLM_BACKEND=anthropic

# Production — Anthropic Claude (needs an API key)
ANTHROPIC_API_KEY=

# Local testing — LM Studio (no key needed; runs 100% offline)
# 1. Download LM Studio: https://lmstudio.ai
# 2. Load a model that supports tool/function calling
#    (e.g. Llama-3.1-8B-Instruct, Qwen2.5-7B-Instruct, Mistral-Nemo-Instruct)
# 3. Enable the local server (default port 1234)
# 4. Copy the model identifier from the LM Studio UI and paste it below
# 5. Set LLM_BACKEND=lm_studio
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=local-model

# ── Optional: Indic translation (IndicTrans2 via HF Inference API) ───────────
HF_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Session storage ───────────────────────────────────────────────────────────
# memory = lost on restart | postgres = persisted (default in Docker)
SESSION_BACKEND=postgres
DATABASE_URL=postgresql://cropcompass:cropcompass_secret@localhost:5432/cropcompass
