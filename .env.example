# ── LLM backend ──────────────────────────────────────────────────────────────
# Options: anthropic | lm_studio
LLM_BACKEND=anthropic

# Production — Anthropic Claude (needs an API key)
ANTHROPIC_API_KEY=

# Local testing — LM Studio (no key needed; runs 100% offline)
# 1. Download LM Studio: https://lmstudio.ai
# 2. Load a model that supports tool/function calling
#    (e.g. qwen/qwen3-coder-30b, Qwen2.5-7B-Instruct, Llama-3.1-8B-Instruct)
# 3. Enable the local server (default port 1234)
# 4. IMPORTANT: copy the EXACT model identifier from the LM Studio UI / from
#    `curl http://localhost:1234/v1/models` and paste it below. A wrong/placeholder
#    id (e.g. "local-model") makes LM Studio return HTTP 400.
# 5. Set LLM_BACKEND=lm_studio
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_MODEL=qwen/qwen3-coder-30b

# ── Optional: Indic translation (IndicTrans2 via HF Inference API) ───────────
HF_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Session storage ───────────────────────────────────────────────────────────
# memory = lost on restart | postgres = persisted (default in Docker)
SESSION_BACKEND=postgres
DATABASE_URL=postgresql://cropcompass:cropcompass_secret@localhost:5432/cropcompass

# ── MCP servers ───────────────────────────────────────────────────────────────
# Comma-separated base URLs the agent auto-discovers tools from on startup.
# Docker default (set in docker-compose.yml): http://db-mcp:9101,http://chroma-mcp:9103
# For a local (non-Docker) run, point at localhost:
MCP_SERVER_URLS=http://localhost:9101,http://localhost:9103
MCP_REQUEST_TIMEOUT_S=15

# ── ChromaDB knowledge store ──────────────────────────────────────────────────
# The chroma-mcp talks to a standalone ChromaDB container over HTTP.
#   HTTP mode  (Docker / production): set CHROMA_HOST (+ CHROMA_PORT).
#   Embedded   (local dev only):      leave CHROMA_HOST empty -> uses CHROMA_PATH.
CHROMA_HOST=chroma
CHROMA_PORT=8000
# Embedded-mode store path (only used when CHROMA_HOST is empty).
CHROMA_PATH=data/chromadb
# Multilingual embedder — MUST match the model the store was built with.
# In Docker this model is BAKED into the chroma-mcp image at build time and the
# container runs fully offline (HF_HUB_OFFLINE=1), so no HuggingFace access is
# needed at runtime. For a local (non-Docker) run it's fetched/cached from HF.
CHROMA_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Collections inside the store (English-first, with Tamil fallback).
CHROMA_PRIMARY_COLLECTION=icar_knowledge_en
CHROMA_FALLBACK_COLLECTION=icar_knowledge

# ── Agent service ─────────────────────────────────────────────────────────────
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
ALLOWED_ORIGINS=*
# Max planner tool-use iterations before the loop gives up.
MAX_PLANNER_ITERATIONS=6
